# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Local cache artifacts (keep processed.bin committed for Vercel builds)
data/.cache/*
!data/.cache/
!data/.cache/processed.bin

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
old_predictive-maintenance/predictive-maintenance.css
old_predictive-maintenance/predictive-maintenance.html
old_predictive-maintenance/predictive-maintenance.js
